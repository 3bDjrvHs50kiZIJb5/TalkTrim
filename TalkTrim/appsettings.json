{
  "NeoAdmin": {
    "IsSwagger": true,
    "DataType": "Sqlite",
    "ConnectionString": "Data Source=neoadmin.db",
    "AutoSyncStructure": true,
    "MonitorCommand": false,
    "SeedAdminUserName": "admin",
    "SeedAdminPassword": "admin",
    "WorkId": 1,
    "FileUpload": {
      "Directory": "uploads",
      "DateTimeDirectory": "yyyyMMdd",
      "Md5": false,
      "MaxSize": 104857600,
      "IncludeExtension": [],
      "ExcludeExtension": [ ".exe", ".dll", ".jar" ]
    }
  },
  "DashScope": {
    "ApiKey": "",
    "LanguageHints": [ "zh" ],
    "TranslateTarget": "中文",
    "TranslateConcurrency": 3,
    "SplitLongCuesEnabled": true,
    "CueSplitMaxWords": 18,
    "CueSplitMaxDurationMs": 8000,
    "CueSplitFallbackMaxChars": 42,
    "DisfluencyRemovalEnabled": false
  },
  "Oss": {
    "Enabled": false,
    "Region": "oss-ap-northeast-1.aliyuncs.com",
    "Bucket": "",
    "AccessKeyId": "",
    "AccessKeySecret": "",
    "Prefix": "talktrim/",
    "SignedUrlExpireSeconds": 7200
  }
}
