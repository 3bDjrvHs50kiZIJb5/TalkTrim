@namespace TalkTrim.Components.Video
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Hosting
@using TalkTrim.Services
@using NeoAdmin.Blazor.Extensions
@using NeoAdmin.Blazor.Services

<div class="space-y-2">
    <Label For="@InputId">视频素材URL</Label>
    @if (HasVideo)
    {
        <div class="relative w-full max-w-md">
            <video controls
                   class="w-full rounded-md border bg-background"
                   src="@NavigationManager.ToMediaUrl(VideoFileUrl)">
                您的浏览器不支持视频预览。
            </video>
            <Button Type="ButtonType.Button"
                    Variant="ButtonVariant.Secondary"
                    Size="ButtonSize.Icon"
                    Class="absolute right-2 top-2 z-10 h-8 w-8 rounded-full bg-background/90 shadow-sm"
                    Title="清除视频"
                    OnClick="ClearVideoAsync">
                <LucideIcon Name="x" Size="16" />
            </Button>
        </div>
        @if (!string.IsNullOrWhiteSpace(VideoFileLocalUrl))
        {
            <div class="space-y-1 max-w-md">
                <Label For="@LocalInputId" Class="text-xs text-muted-foreground">视频素材本地链接</Label>
                <Input Id="@LocalInputId"
                       Class="w-full text-xs"
                       MaxLength="500"
                       ReadOnly="true"
                       Value="@VideoFileLocalUrl" />
                <p class="text-xs text-muted-foreground">
                    识别口播稿与压制时优先使用本地文件提取/读取，无需从 OSS 再下载。
                </p>
            </div>
        }
    }
    else
    {
        <Input Id="@InputId"
               Class="w-full"
               MaxLength="500"
               Placeholder="上传后的素材地址"
               Value="@VideoFileUrl"
               ValueChanged="@(v => VideoFileUrlChanged.InvokeAsync(v ?? string.Empty))" />
        <FileUpload @ref="fileUpload"
                    Files="selectedFiles"
                    FilesChanged="OnFilesChangedAsync"
                    Multiple="false"
                    Accept="video/*"
                    MaxFileSize="524288000"
                    ShowPreview="true"
                    Disabled="isUploading" />
        @if (isUploading)
        {
            <Alert Variant="AlertVariant.Default">
                <LucideIcon Name="loader-circle" Size="16" Class="animate-spin" />
                <AlertTitle>正在上传视频</AlertTitle>
                <AlertDescription Class="space-y-2">
                    <p>@(uploadStatus ?? "正在上传，请稍候…")</p>
                    @if (uploadPercent > 0)
                    {
                        <div class="flex items-center gap-2">
                            <Progress Value="@uploadPercent" Max="100" Class="flex-1" />
                            <span class="shrink-0 text-xs tabular-nums text-muted-foreground">@uploadPercent%</span>
                        </div>
                    }
                </AlertDescription>
            </Alert>
        }
        else
        {
            <p class="text-xs text-muted-foreground">
                @UploadHint
            </p>
        }
    }
</div>

@code {
    private const string UploadDirectory = "video";

    [Parameter]
    public string InputId { get; set; } = "project-video";

    [Parameter]
    public string LocalInputId { get; set; } = "project-video-local";

    [Parameter]
    public string VideoFileUrl { get; set; } = string.Empty;

    [Parameter]
    public string VideoFileLocalUrl { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> VideoFileUrlChanged { get; set; }

    [Parameter]
    public EventCallback<string> VideoFileLocalUrlChanged { get; set; }

    [Inject]
    private FileService FileService { get; set; } = default!;

    [Inject]
    private OssUploadService OssUploadService { get; set; } = default!;

    [Inject]
    private IWebHostEnvironment WebHostEnvironment { get; set; } = default!;

    [Inject]
    private IToastService ToastService { get; set; } = default!;

    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    private FileUpload? fileUpload;
    private List<IBrowserFile> selectedFiles = [];
    private bool isUploading;
    private int uploadPercent;
    private string? uploadStatus;

    private bool HasVideo => !string.IsNullOrWhiteSpace(VideoFileUrl);

    private string UploadHint =>
        OssUploadService.IsEnabled
            ? "选择视频后将先保存到本站，再上传到阿里云 OSS；OSS 地址填入上方，本地链接用于提取 WAV。"
            : "选择视频后将自动上传到本站，地址会填入上方 URL。";

    private async Task ClearVideoAsync()
    {
        await VideoFileUrlChanged.InvokeAsync(string.Empty);
        await VideoFileLocalUrlChanged.InvokeAsync(string.Empty);
        selectedFiles = [];
        if (fileUpload is not null)
        {
            await fileUpload.ClearFiles();
        }
    }

    private async Task OnFilesChangedAsync(List<IBrowserFile> files)
    {
        selectedFiles = files;
        if (files.Count == 0 || isUploading)
        {
            return;
        }

        isUploading = true;
        uploadPercent = 0;
        uploadStatus = "正在准备上传…";
        IProgress<UploadProgressReport> uploadProgress = new System.Progress<UploadProgressReport>(report =>
        {
            uploadPercent = report.Percent;
            uploadStatus = report.Message;
            _ = InvokeAsync(StateHasChanged);
        });

        try
        {
            string url;
            string localUrl = string.Empty;
            if (OssUploadService.IsEnabled)
            {
                var fileWithProgress = BrowserFileUploadHelper.WithProgress(
                    files[0],
                    uploadProgress,
                    percentStart: 0,
                    percentEnd: 42,
                    message: "正在保存到本站…");
                var uploaded = await FileService.UploadFileAsync(fileWithProgress, UploadDirectory, isRename: true);
                localUrl = uploaded.LinkUrl;

                if (!MediaUrlHelper.TryResolveWebRootPhysicalPath(
                        localUrl,
                        WebHostEnvironment.WebRootPath,
                        out var physicalPath))
                {
                    throw new InvalidOperationException("本地视频保存成功，但无法解析文件路径。");
                }

                uploadStatus = "正在上传到 OSS…";
                var extension = Path.GetExtension(physicalPath);
                if (string.IsNullOrWhiteSpace(extension))
                {
                    extension = Path.GetExtension(files[0].Name);
                }

                url = await OssUploadService.UploadLocalFileWithProgressAsync(
                    physicalPath,
                    extension,
                    uploadProgress,
                    CancellationToken.None);
            }
            else
            {
                var fileWithProgress = BrowserFileUploadHelper.WithProgress(
                    files[0],
                    uploadProgress,
                    percentStart: 0,
                    percentEnd: 100,
                    message: "正在上传视频…");
                var uploaded = await FileService.UploadFileAsync(fileWithProgress, UploadDirectory, isRename: true);
                uploadPercent = 100;
                uploadStatus = "上传完成";
                url = uploaded.LinkUrl;
                localUrl = url;
            }

            await VideoFileUrlChanged.InvokeAsync(url);
            await VideoFileLocalUrlChanged.InvokeAsync(localUrl);
            await InvokeAsync(StateHasChanged);
            ToastService.Success(
                "视频",
                OssUploadService.IsEnabled
                    ? "已保存本地并上传到阿里云 OSS"
                    : "上传成功，已填入 URL");
        }
        catch (Exception ex)
        {
            ToastService.Error("视频上传失败", ex.Message);
        }
        finally
        {
            selectedFiles = [];
            if (fileUpload is not null)
            {
                await fileUpload.ClearFiles();
            }

            isUploading = false;
            uploadPercent = 0;
            uploadStatus = null;
        }
    }
}
