@namespace TalkTrim.Components.Video
@using Microsoft.AspNetCore.Components.Forms
@using TalkTrim.Entities.Video
@using VideoProject = TalkTrim.Entities.Video.Project
@using TalkTrim.Services
@using NeoAdmin.Blazor.Extensions
@using NeoAdmin.Blazor.Services

<div class="space-y-2">
    <div class="flex items-center justify-between gap-2">
        <Label For="@InputId">视频片尾 URL</Label>
        <Button Type="ButtonType.Button"
                Variant="ButtonVariant.Outline"
                Size="ButtonSize.Small"
                Disabled="@(!CanCopyFromPrevious || _isCopying)"
                Title="@GetCopyFromPreviousTitle()"
                OnClick="CopyFromPreviousAsync">
            @if (_isCopying)
            {
                <span>获取中…</span>
            }
            else
            {
                <span>从上一条视频获取</span>
            }
        </Button>
    </div>
    <Input Id="@InputId"
           Class="w-full"
           MaxLength="500"
           Placeholder="可选；上传片尾视频后压制完成会自动接到成片末尾"
           Value="@OutroVideoUrl"
           ValueChanged="@(v => OutroVideoUrlChanged.InvokeAsync(v ?? string.Empty))" />
    @if (HasOutro)
    {
        <div class="relative w-full max-w-md">
            <video controls
                   class="w-full rounded-md border bg-background"
                   src="@NavigationManager.ToMediaUrl(OutroVideoUrl)">
                您的浏览器不支持视频预览。
            </video>
            <Button Type="ButtonType.Button"
                    Variant="ButtonVariant.Secondary"
                    Size="ButtonSize.Icon"
                    Class="absolute right-2 top-2 z-10 h-8 w-8 rounded-full bg-background/90 shadow-sm"
                    Title="清除片尾"
                    OnClick="ClearOutroAsync">
                <LucideIcon Name="x" Size="16" />
            </Button>
        </div>
    }
    else
    {
        <FileUpload @ref="fileUpload"
                    Files="selectedFiles"
                    FilesChanged="OnFilesChangedAsync"
                    Multiple="false"
                    Accept="video/*"
                    MaxFileSize="524288000"
                    ShowPreview="true"
                    Disabled="isUploading" />
        <p class="text-xs text-muted-foreground">
            @UploadHint
        </p>
    }
</div>

@code {
    private const string UploadDirectory = "video";

    [Parameter]
    public string InputId { get; set; } = "project-outro";

    [Parameter]
    public long ProjectId { get; set; }

    [Parameter]
    public long UserId { get; set; }

    [Parameter]
    public string OutroVideoUrl { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> OutroVideoUrlChanged { get; set; }

    [Inject]
    private IFreeSql FreeSql { get; set; } = default!;

    [Inject]
    private FileService FileService { get; set; } = default!;

    [Inject]
    private OssUploadService OssUploadService { get; set; } = default!;

    [Inject]
    private IToastService ToastService { get; set; } = default!;

    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    private FileUpload? fileUpload;
    private List<IBrowserFile> selectedFiles = [];
    private bool isUploading;
    private bool _isCopying;

    private bool HasOutro => !string.IsNullOrWhiteSpace(OutroVideoUrl);

    private bool CanCopyFromPrevious => UserId > 0;

    private string? GetCopyFromPreviousTitle()
    {
        if (UserId <= 0)
        {
            return "请先保存项目后再获取";
        }

        return "复制上一条视频的片尾 URL（按 ID 倒序的上一条）";
    }

    private string UploadHint =>
        isUploading
            ? "正在上传，请稍候…"
            : OssUploadService.IsEnabled
                ? "选择片尾视频后将自动上传到阿里云 OSS，地址会填入上方。"
                : "选择片尾视频后将自动上传，地址会填入上方 URL。压制时若已填写，会拼接到成片末尾。";

    private async Task ClearOutroAsync()
    {
        await OutroVideoUrlChanged.InvokeAsync(string.Empty);
        selectedFiles = [];
        if (fileUpload is not null)
        {
            await fileUpload.ClearFiles();
        }
    }

    private async Task CopyFromPreviousAsync()
    {
        if (!CanCopyFromPrevious || _isCopying)
        {
            return;
        }

        _isCopying = true;
        try
        {
            var query = FreeSql.Select<VideoProject>()
                .Where(p => p.UserId == UserId)
                .Where(p => !string.IsNullOrWhiteSpace(p.OutroVideoUrl));

            if (ProjectId > 0)
            {
                query = query.Where(p => p.Id < ProjectId);
            }

            var previous = await query
                .OrderByDescending(p => p.Id)
                .FirstAsync(p => new { p.OutroVideoUrl, p.ProjectName });

            if (previous is null || string.IsNullOrWhiteSpace(previous.OutroVideoUrl))
            {
                ToastService.Warning("无可用片尾", "未找到上一条已填写片尾 URL 的视频项目。");
                return;
            }

            await OutroVideoUrlChanged.InvokeAsync(previous.OutroVideoUrl);
            selectedFiles = [];
            if (fileUpload is not null)
            {
                await fileUpload.ClearFiles();
            }

            var projectLabel = string.IsNullOrWhiteSpace(previous.ProjectName)
                ? "上一条视频"
                : $"「{previous.ProjectName}」";
            ToastService.Success("视频片尾", $"已从{projectLabel}复制片尾 URL");
        }
        catch (Exception ex)
        {
            ToastService.Error("获取片尾失败", ex.Message);
        }
        finally
        {
            _isCopying = false;
        }
    }

    private async Task OnFilesChangedAsync(List<IBrowserFile> files)
    {
        selectedFiles = files;
        if (files.Count == 0 || isUploading)
        {
            return;
        }

        isUploading = true;
        try
        {
            string url;
            if (OssUploadService.IsEnabled)
            {
                url = await OssUploadService.UploadBrowserFileAsync(files[0]);
            }
            else
            {
                var uploaded = await FileService.UploadFileAsync(files[0], UploadDirectory, isRename: true);
                url = uploaded.LinkUrl;
            }

            await OutroVideoUrlChanged.InvokeAsync(url);
            await InvokeAsync(StateHasChanged);
            ToastService.Success("视频片尾", OssUploadService.IsEnabled ? "已上传到阿里云 OSS" : "上传成功，已填入 URL");
        }
        catch (Exception ex)
        {
            ToastService.Error("片尾视频上传失败", ex.Message);
        }
        finally
        {
            selectedFiles = [];
            if (fileUpload is not null)
            {
                await fileUpload.ClearFiles();
            }

            isUploading = false;
        }
    }
}
